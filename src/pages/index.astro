---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Banner from "../components/sections/Banner.astro";
import Hero from "../components/sections/Hero.astro";
import Details from "../components/sections/Details.astro";
import Products from "../components/sections/Products.astro";
import Contact from "../components/sections/Contact.astro";
import Order from "../components/sections/Order.astro";
import Projects from "../components/sections/Projects.astro";
import BusinessSolutions from "../components/sections/BusinessSolutions.astro";
import Faq from "../components/sections/Faq.astro";
import FinalCta from "../components/sections/FinalCta.astro";
---

<Layout>
  <Header />

  <main class="pt-16 lg:pt-20">
    <Banner />
    <Hero />
    <Details />
    <Products />
    <Contact />
    <Order />
    <!-- Wrapper для sticky-curtain эффекта Projects → BusinessSolutions.
         Projects (sticky top-20) залипает у шапки только пока этот контейнер
         тянется ниже — когда BusinessSolutions полностью перекрывает Projects
         и контейнер заканчивается, sticky отпускает Projects, и она уезжает
         вверх вместе с BS. Без wrapper-а контейнинг-блок = main, sticky
         висит до футера и Projects вылезает из-под BS на следующих секциях.

         id="projects" на этом wrapper-е (а не на самой Projects-секции),
         чтобы anchor-навигация (#projects из меню шапки) работала
         предсказуемо. У sticky-элементов getBoundingClientRect() возвращает
         visual position, а не natural — когда Projects scrolled-past и
         unstuck, scrollIntoView промахивается на дельту = (visual − natural).
         Wrapper статичный → rect.top = natural top, scroll работает чисто. -->
    <div id="projects">
      <Projects />
      <BusinessSolutions />
    </div>
    <!-- Wrapper для clipping Faq glow-эллипса. У Faq внутри `absolute`-
         эллипс h:72.375rem, который на мобиле выходит за пределы FinalCta
         и расширяет body.scrollHeight на ~300px ниже DAICHI (видимая
         «дыра» в конце страницы). overflow-clip обрезает эллипс по
         wrapper.bottom = FinalCta.bottom = page end. На десктопе
         оставляем visible — там эллипс умещается в Faq+FinalCta без
         выхода за page end (см. вычисления в комментарии Faq.astro). -->
    <div class="overflow-clip lg:overflow-visible">
      <Faq />
      <FinalCta />
    </div>
  </main>
</Layout>

<!-- reveal-on-scroll: единый IntersectionObserver на всех data-reveal элементах -->
<script>
  import "../lib/reveal.ts";
  import "../lib/lazy-video.ts";
  import "../lib/mobile-reveal.ts";
  import "../lib/mobile-curtain.ts";
</script>
