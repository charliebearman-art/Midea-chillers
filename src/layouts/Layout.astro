---
import "../styles/global.css";
import Toast from "../components/Toast.astro";
import { getImage } from "astro:assets";
import heroCityImg from "../assets/images/hero-city.jpg";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Модульные чиллеры Midea со встроенным гидромодулем — Daichi",
  description = "Уникальное техническое решение для рынка РФ. Чиллеры Midea с гидромодулем — всегда в наличии, технология Plug&Play, на 30% ниже расход электроэнергии.",
} = Astro.props;

// Preload оптимизированного WebP hero-poster — тот же URL, что использует
// Hero.astro в <video poster>. width:1440 совпадает с Hero — getImage
// кешируется, генерится один файл.
const heroCityWebp = await getImage({ src: heroCityImg, format: "webp", width: 1440 });
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0d12" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Manrope как fallback для Gotham Pro. Async-загрузка через preload
         + onload-swap, чтобы не блокировать первый рендер (~600ms на 4G).
         Gotham Pro preload'ится отдельно ниже как primary шрифт. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700&display=swap"
      />
    </noscript>

    <!-- preload критических шрифтов -->
<link rel="preload" href="/fonts/GothamPro-Bold.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/GothamPro-Medium.woff2" as="font" type="font/woff2" crossorigin />

    <!-- preload hero-картинки для LCP. fetchpriority="high" сообщает
         браузеру, что этот ресурс критичен и нужен раньше остальных. -->
    <link rel="preload" as="image" href={heroCityWebp.src} type="image/webp" fetchpriority="high" />

    <title>{title}</title>

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/og.jpg" />
  </head>
  <body>
    <Toast />
    <slot />

    <!-- --sw: ширина нативного скроллбара (vw - clientWidth). Header
         использует её как right-offset, чтобы fixed-элемент имел ширину
         body. На Mac overlay = 0 (no-op). На системах где scroll-bar
         занимает layout-место (Windows/Linux/Chrome-always-show) — даёт
         компенсацию, чтобы CTA не вылезал за правый край сетки. -->
    <script is:inline>
      (function () {
        var update = function () {
          var sw = window.innerWidth - document.documentElement.clientWidth;
          document.documentElement.style.setProperty("--sw", sw + "px");
        };
        update();
        window.addEventListener("resize", update);
        // Скроллбар может появляться/исчезать во время скролла на некоторых
        // OS — пересчитываем, чтобы header оставался в синке с body.
        window.addEventListener("scroll", update, { passive: true });
      })();
    </script>

    <!-- Плавный скролл страницы (SmoothScroll.js) — те же параметры,
         что у aircon-wifi.ru: 800 ms догон + step 75 px. -->
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/smoothscroll/1.4.10/SmoothScroll.min.js"
      integrity="sha256-huW7yWl7tNfP7lGk46XE+Sp0nCotjzYodhVKlwaNeco="
      crossorigin="anonymous"
      is:inline></script>
    <script is:inline>
      SmoothScroll({
        animationTime: 800,
        stepSize: 75,
        accelerationDelta: 30,
        accelerationMax: 2,
        keyboardSupport: true,
        arrowScroll: 50,
        pulseAlgorithm: true,
        pulseScale: 4,
        pulseNormalize: 1,
        touchpadSupport: true,
      });
    </script>
  </body>
</html>