---
/**
 * Один бейдж в стиле Apple Dynamic Island: циклит между двумя
 * состояниями. Ширина морфит пружинной iOS-кривой, контент кросс-
 * фейдится с blur-маской — глаз видит единое мягкое превращение
 * вместо двух кадров.
 *
 * Архитектура (две независимые оси):
 *  - LAYOUT: класс --absolute. Без него state в нормальном потоке
 *    и драйвит pill.offsetWidth (нативный flex shrink-to-fit, без
 *    ручных getBoundingClientRect). С ним — overlay inset:0,
 *    flex-центрированный, не влияет на layout.
 *  - VISIBILITY: класс --hidden. opacity:0 + blur(4px) с transition.
 *    Независим от --absolute → можно держать state absolute и
 *    одновременно делать ему cross-fade без ожиданий.
 *
 * Tick:
 *  1. Снэпшот before = pill.offsetWidth.
 *  2. Лочим pill.style.width = before, делаем current --absolute
 *     (next уже был --absolute --hidden) — pill теперь "висит" на
 *     явной ширине.
 *  3. Cross-fade одновременно с width-transition:
 *     current += --hidden (fade out), next −= --hidden (fade in),
 *     pill.style.width = widths[next] (transition подхватит).
 *  4. По окончании: next −= --absolute (в поток), снимаем inline
 *     width — натуральная ширина, адаптируется к ресайзу/шрифтам.
 *
 * Без JS: статичный pill с первым состоянием (state 1 в потоке,
 * state 2 absolute+hidden).
 * prefers-reduced-motion: цикл отключён.
 */
---

<div
  data-morph-pill
  class="morph-pill relative inline-flex items-center justify-center rounded-pill border-2 border-pill px-3 h-[2.0625rem] text-body font-medium align-middle lg:text-h4"
>
  <span data-morph-state="1" class="morph-pill__state inline-flex items-center gap-2"
    ><img src="/images/icon-star.svg" alt="" loading="eager" width="19" height="20" class="h-5 w-auto" /><span>Эксклюзив</span></span>
  <span data-morph-state="2" class="morph-pill__state morph-pill__state--absolute morph-pill__state--hidden inline-flex items-center gap-2"
    ><img src="/images/icon-bolt.svg" alt="" loading="eager" width="13" height="18" class="h-5 w-auto" /><span>Уже на складе</span></span>
</div>

<style>
  .morph-pill {
    transition: width 600ms cubic-bezier(0.32, 0.72, 0, 1);
    will-change: width;
  }

  .morph-pill__state {
    white-space: nowrap;
    transition:
      opacity 380ms cubic-bezier(0.32, 0.72, 0, 1),
      filter 380ms cubic-bezier(0.32, 0.72, 0, 1);
    will-change: opacity, filter;
  }

  /* LAYOUT-ось: убирает state из потока и кладёт overlay-ом поверх pill. */
  .morph-pill__state--absolute {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  /* VISIBILITY-ось: opacity + blur. Независима от --absolute. */
  .morph-pill__state--hidden {
    opacity: 0;
    filter: blur(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .morph-pill,
    .morph-pill__state {
      transition: none !important;
    }
  }
</style>

<script>
  const ABSOLUTE = "morph-pill__state--absolute";
  const HIDDEN = "morph-pill__state--hidden";
  const pills = document.querySelectorAll<HTMLElement>("[data-morph-pill]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  pills.forEach((pill) => {
    const states = Array.from(
      pill.querySelectorAll<HTMLElement>("[data-morph-state]"),
    );
    if (states.length < 2) return;

    let current = 0;

    /** Меряем естественную ширину pill для каждого state-а через flex
     *  shrink-to-fit. Toggle классов синхронно — браузер не паинтит
     *  промежуток. HIDDEN не трогаем (на layout не влияет). */
    const measure = () => {
      const savedWidth = pill.style.width;
      pill.style.width = "";
      const widths: number[] = [];
      for (let i = 0; i < states.length; i++) {
        states.forEach((s, j) => s.classList.toggle(ABSOLUTE, j !== i));
        widths.push(pill.offsetWidth);
      }
      states.forEach((s, j) => s.classList.toggle(ABSOLUTE, j !== current));
      pill.style.width = savedWidth;
      return widths;
    };

    let widths = measure();

    if (reducedMotion) return;

    if ("fonts" in document) {
      document.fonts.ready.then(() => {
        widths = measure();
      });
    }

    const tick = () => {
      const next = (current + 1) % states.length;

      // Лочим текущую ширину inline-стилем — отвязываемся от in-flow.
      pill.style.width = `${pill.offsetWidth}px`;

      // current уходит из потока (overlay, всё ещё видим — HIDDEN добавим
      // строкой ниже одновременно с fade-in next-а).
      states[current].classList.add(ABSOLUTE);

      // Принудительный reflow перед запуском transition-ов, чтобы
      // браузер зафиксировал стартовое состояние.
      void pill.offsetWidth;

      // Cross-fade + width-анимация одновременно.
      states[current].classList.add(HIDDEN);
      states[next].classList.remove(HIDDEN);
      pill.style.width = `${widths[next]}px`;

      // По окончании width-transition (600мс): next возвращаем в поток,
      // снимаем inline width. Запас 50мс на дрожание.
      window.setTimeout(() => {
        states[next].classList.remove(ABSOLUTE);
        pill.style.width = "";
      }, 650);

      current = next;
    };

    window.setInterval(tick, 4000);
  });
</script>
