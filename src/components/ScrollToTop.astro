---
/**
 * Scroll-to-top кнопка («лифт») — fixed в правом нижнем углу.
 *
 * Появляется когда пользователь проскролил больше 1×viewport-height
 * (= хорошо ниже Hero, всё ещё на странице). Клик плавно скроллит
 * к верху через window.scrollTo({ top: 0, behavior: 'smooth' }).
 *
 * Скрыта на header (top:0) и сразу после загрузки. Z-index 40 —
 * выше modal-backdrop'ов? нет, ниже — модалки z-50. Не перекрывает
 * fixed-header (z-50).
 */
---

<button
  type="button"
  data-scroll-to-top
  aria-label="Наверх"
  class="fixed bottom-4 right-4 z-40 flex h-10 w-10 items-center justify-center rounded-full bg-brand text-white shadow-[0_4px_12px_rgba(0,0,0,0.4)] opacity-0 pointer-events-none transition-[opacity,transform] duration-300 ease-out hover:bg-brand-dark hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-ink-900 lg:bottom-8 lg:right-8 lg:h-12 lg:w-12"
>
  <svg
    width="16"
    height="16"
    viewBox="0 0 16 16"
    fill="currentColor"
    aria-hidden="true"
    class="h-3 w-3 lg:h-4 lg:w-4"
  >
    <path
      fill-rule="evenodd"
      clip-rule="evenodd"
      d="M8 2.5a.75.75 0 0 1 .53.22l5 5a.75.75 0 0 1-1.06 1.06L8.75 5.06V13a.75.75 0 0 1-1.5 0V5.06L3.53 8.78a.75.75 0 0 1-1.06-1.06l5-5A.75.75 0 0 1 8 2.5Z"
    />
  </svg>
</button>

<style>
  [data-scroll-to-top][data-visible="true"] {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  const btn = document.querySelector<HTMLElement>("[data-scroll-to-top]");

  if (btn) {
    /** Показываем после прокрутки на 1×vh (≈ конец Hero). До этого —
     *  кнопка перегружает экран на чистом hero-state. */
    const update = () => {
      const threshold = window.innerHeight;
      if (window.scrollY > threshold) {
        btn.dataset.visible = "true";
      } else {
        btn.dataset.visible = "false";
      }
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update, { passive: true });

    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>
