---
import { asset } from "../../lib/asset";
/**
 * Финальный блок «Выбирайте надёжность с чиллерами Midea» (figma 748:3199).
 * Заголовок (text-h1, "с чиллерами Midea" в брэнд-градиенте) +
 * горизонтальная связка логотипов: midea99 × DAICHI.
 * Сидит в конце страницы перед футером.
 */
---

<!-- data-mobile-slide-up на последней секции страницы оставляет
     остаточный translateY > 0 на максимуме скролла (progress не
     достигает 1, потому что viewport уже уперся в page bottom).
     Это даёт визуальный сдвиг DAICHI вниз и кажущуюся «дыру» под
     ним. На FinalCta анимацию не используем. -->
<section class="container-x pt-6 pb-16 lg:py-16">
  <div class="flex flex-col items-center gap-12 lg:gap-16">
    <h2
      data-reveal
      class="text-center text-h2 font-medium text-text-primary lg:text-h1"
    >
      Выбирайте надёжность<br />
      <span class="gradient-text">c&nbsp;чиллерами Midea</span>
    </h2>

    <!-- Связка лого. Mobile: вертикальная стопка midea99 / × / DAICHI,
         центрирована. Desktop: горизонтальный ряд по базовой линии букв.
         Mb-[11px] компенсирует «свисающий» хвост «M» у midea99
         (viewBox 0 0 134 48; буквы кончаются на y≈41.44 → 6.56*80/48≈11px). -->
    <div data-reveal data-reveal-delay="120" class="flex flex-col items-center gap-4 lg:flex-row lg:items-end lg:gap-8">
      <img
        src={asset("/images/logo-midea99.svg")}
        alt="midea99"
        width="222"
        height="80"
        class="h-12 w-auto lg:h-20"
      />
      <span
        aria-hidden="true"
        class="text-h2 font-medium text-text-primary lg:mb-[11px]"
      >×</span>
      <img
        src={asset("/images/logo-daichi.svg")}
        alt="Daichi"
        width="222"
        height="80"
        class="h-8 w-auto lg:mb-[11px] lg:h-12"
      />
    </div>
  </div>
</section>
