      { label: "Срок гарантии (мес.)", values: ["36", "36", "36", "36", "36", "36", "36", "36", "36"] },
    ],
  },
];
---

<section
  id="products"
  data-mobile-slide-up
  class="products-curtain relative z-30 rounded-t-3xl bg-ink-surface lg:rounded-t-[2rem]"
>
  <div class="container-x py-12 lg:px-10 lg:py-20">
    <!-- Heading: на мобиле центр + gap-3, h2 24px; на десктопе слева + gap-6, h1 48px. -->
    <div class="mb-6 flex flex-col gap-3 text-center lg:mb-12 lg:gap-6 lg:text-left">
    <p data-reveal class="text-h4 font-medium text-text-primary">Модельный ряд</p>
    <h2 data-reveal data-reveal-delay="80" class="text-h2 font-medium text-text-primary lg:text-h1">
      <span class="gradient-text">3 серии чиллеров Midea</span><br />
      со встроенным гидромодулем
    </h2>
  </div>

  <div class="flex flex-col gap-4 lg:gap-6">
    {products.map((p, idx) => (
      <div data-reveal data-reveal-delay={idx * 80}>
        <ProductCard {...p} />
      </div>
    ))}
  </div>

  <!-- Custom Solutions: на мобиле image-сверху h-190 + текст-снизу centered;
       на десктопе image-фон + текст-оверлей слева. -->
  <article
    data-reveal
    class="mt-4 flex flex-col gap-4 lg:relative lg:mt-16 lg:gap-0 lg:overflow-hidden lg:rounded-xl lg:bg-gradient-to-br lg:from-slate-200 lg:to-sky-200"
  >
    <div class="relative h-[11.875rem] w-full overflow-hidden rounded-2xl lg:absolute lg:inset-0 lg:h-auto lg:rounded-xl">
      <img
        src="/images/custom-solutions.jpg"
        alt=""
        width="1360" height="521"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
      />
    </div>
    <div class="relative flex flex-col gap-2 text-center text-text-primary lg:min-h-[32.5625rem] lg:gap-12 lg:px-10 lg:py-12 lg:text-left lg:text-text-inverse lg:justify-between">
      <h3 class="text-h4 font-medium lg:max-w-[45rem] lg:text-h2">
        Серии ECO mini и AQUA THERMAL GM доступны в варианте{" "}
        <span class="text-brand-dark">с низкотемпературной доработкой</span>
      </h3>
      <p class="text-t12 lg:max-w-[27.25rem] lg:text-body">
        Доработаем серии для эксплуатации при наружной температуре воздуха до −40°C от 3 рабочих дней
      </p>
    </div>
  </article>
  </div>
</section>
