---
import Button from "../Button.astro";
import VideoModal from "../VideoModal.astro";
/**
 * Блок "Заказывайте чиллеры Midea в компании «Даичи»".
 * Заголовок (text-h1, "Заказывайте" — в брэнд-градиенте) + сетка УТП-карточек
 * 4-кол × 2-ряда (Figma node 748:3134):
 *
 * Ряд 1: [№1 в мире] [Видео-карточка span 2] [Эксклюзивная складская программа]
 * Ряд 2: [Фото-карточка] [Серийное производство] [Только в «Даичи»] [CTA — Оставить заявку]
 *
 * Все УТП-карточки — `bg-[#1d2025]` (background/surface-2 из Figma), p-6, rounded-3xl, h-80,
 * с заголовком (text-h2 — первое слово в gradient-text) сверху и описанием
 * (text-body) внизу через flex justify-between.
 *
 * Видео-карточка: bg-фон с Землёй (image-fill в Figma — отдельный asset
 * `usp-earth.jpg`) + pill-кнопка "Смотреть видео" в правом нижнем углу.
 * Фото-карточка: просто `<img>` с rounded-3xl + cover.
 * CTA: bg-brand, "Оставить заявку" (text-h2 white) сверху, белый круг с
 * arrow-next справа внизу. Ссылка на #contact.
 */
---

<!-- Bg задаём через linear-gradient: солидный #0f1115 на 99%, затем за
     последние ~200px плавно угасает в transparent. Иначе hard-edge снизу
     Order'а образует видимый «шов» в месте, где из-под него начинает
     проявляться глоу-эллипс (он же -z-10 внутри Order и закрыт bg-ink-base
     внутри его bbox, но виден ниже — где Projects прозрачен). Плавный
     fade-out низа Order'а делает переход бесшовным. -->
<section
  id="order"
  data-order-section
  class="relative z-10 rounded-t-3xl lg:-mt-[60px]"
  style="transform: translateY(60px); background: linear-gradient(to bottom, #0f1115 0%, #0f1115 calc(100% - 240px), transparent 100%);"
>
  <!-- Размытый эллипс-glow (Figma 894:4635). Order имеет z-10, поэтому
       нижняя часть эллипса, выходящая за нижнюю границу Order, остаётся
       видимой над Projects (его bg-ink-base не перекрывает). Один большой
       эллипс вместо пары — гарантирует непрерывное свечение без видимой
       границы на стыке секций (Projects-овский clip раньше создавал шов). -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-[60%] -right-[10%] -z-10 size-[88rem] max-w-[120vw] rounded-full bg-[radial-gradient(circle,rgba(50,163,253,0.7)_0%,rgba(50,163,253,0.3)_35%,transparent_70%)] blur-[120px]"
  >
  </div>

  <div class="container-x py-12 lg:py-20">
    <h2 data-reveal class="text-center text-h2 font-medium text-text-primary lg:text-h1">
      <span class="gradient-text">Заказывайте</span><br />
      чиллеры Midea в&nbsp;компании «Даичи»
    </h2>

    <div class="mt-6 flex flex-col gap-2 lg:mt-12 lg:gap-6">
    <!-- Ряд 1: УТП | Видео | УТП -->
    <div class="grid grid-cols-1 gap-2 lg:h-80 lg:grid-cols-4 lg:gap-6">
      <!-- № 1 в мире -->
      <article
        data-reveal
        class="flex flex-col items-start justify-between gap-4 rounded-2xl bg-[#1d2025] p-4 lg:h-auto lg:gap-0 lg:rounded-3xl lg:p-6"
      >
        <h3 class="text-h4 font-medium text-text-primary lg:text-h2">
          <span class="gradient-text">№&nbsp;1 в&nbsp;мире</span><br />
          по&nbsp;продажам чиллеров
        </h3>
        <p class="text-t12 text-text-primary lg:text-body">
          Компания «Даичи» — лидер рынка по&nbsp;итогам 2024 года
        </p>
      </article>

      <!-- Видео-карточка (span 2) — фон-видео numberonesmall.mp4 + CTA
           «Смотреть видео» в правом нижнем углу. -->
      <article
        data-reveal
        data-reveal-delay="80"
        class="relative h-[9.8125rem] overflow-hidden rounded-2xl bg-[#1d2025] lg:col-span-2 lg:h-auto lg:rounded-3xl"
      >
        <video
          autoplay
          muted
          loop
          playsinline
          preload="none"
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 h-full w-full object-cover"
        >
          <source data-src="/videos/numberonesmall.mp4" type="video/mp4" />
        </video>
        <!-- Mobile: круглая play-кнопка без текста (figma 896:4785).
             Desktop: pill-кнопка «Смотреть видео» + play-иконка. -->
        <button
          type="button"
          data-video-trigger
          aria-label="Смотреть видео"
          class="absolute bottom-4 right-4 flex h-8 w-8 items-center justify-center rounded-full bg-white text-brand lg:hidden"
        >
          <svg viewBox="0 0 14 16" fill="currentColor" aria-hidden="true" class="h-3 w-auto">
            <path d="M13 7.13397C13.6667 7.51887 13.6667 8.48113 13 8.86603L2 15.2206C1.33333 15.6055 0.5 15.1244 0.5 14.3546L0.5 1.64545C0.5 0.875645 1.33333 0.394521 2 0.779421L13 7.13397Z" />
          </svg>
        </button>
        <Button size="md" class="absolute bottom-6 right-6 hidden lg:inline-flex" data-video-trigger>
          Смотреть видео
          <svg
            slot="icon"
            viewBox="0 0 16 16"
            fill="currentColor"
            aria-hidden="true"
            class="h-4 w-4"
          >
            <path d="M5 3v10l8-5z" />
          </svg>
        </Button>
      </article>

      <!-- Эксклюзивная складская программа -->
      <article
        data-reveal
        data-reveal-delay="160"
        class="flex flex-col items-start justify-between gap-4 rounded-2xl bg-[#1d2025] p-4 lg:h-auto lg:gap-0 lg:rounded-3xl lg:p-6"
      >
        <h3 class="text-h4 font-medium text-text-primary lg:text-h2">
          <span class="gradient-text">Эксклюзивная</span><br />
          складская программа
        </h3>
        <p class="text-t12 text-text-primary lg:text-body">
          Мы&nbsp;— первый дистрибьютор в&nbsp;России со&nbsp;складом модульных чиллеров
          со&nbsp;встроенным гидромодулем
        </p>
      </article>
    </div>

    <!-- Ряд 2: Фото | УТП | УТП | CTA -->
    <div class="grid grid-cols-1 gap-2 lg:h-80 lg:grid-cols-4 lg:gap-6">
      <!-- Фото-карточка (небоскрёб) -->
      <article
        data-reveal
        class="relative h-[11.4375rem] overflow-hidden rounded-2xl lg:h-auto lg:rounded-3xl"
      >
        <img
          src="/images/usp-skyscraper.jpg"
          alt="Офис «Даичи»"
          width="1280"
          height="943"
          loading="lazy"
          decoding="async"
          class="pointer-events-none absolute inset-0 h-full w-full object-cover"
        />
      </article>

      <!-- Серийное производство -->
      <article
        data-reveal
        data-reveal-delay="80"
        class="flex flex-col items-start justify-between gap-4 rounded-2xl bg-[#1d2025] p-4 lg:h-auto lg:gap-0 lg:rounded-3xl lg:p-6"
      >
        <h3 class="text-h4 font-medium text-text-primary lg:text-h2">
          <span class="gradient-text">Серийное</span> производство
        </h3>
        <p class="text-t12 text-text-primary lg:text-body">
          Midea — первый китайский производитель, запустивший серийный выпуск модульных
          чиллеров со&nbsp;встроенным гидромодулем
        </p>
      </article>

      <!-- Только в «Даичи» -->
      <article
        data-reveal
        data-reveal-delay="160"
        class="flex flex-col items-start justify-between gap-4 rounded-2xl bg-[#1d2025] p-4 lg:h-auto lg:gap-0 lg:rounded-3xl lg:p-6"
      >
        <h3 class="text-h4 font-medium text-text-primary lg:text-h2">
          <span class="gradient-text">Только</span><br />
          в&nbsp;«Даичи»
        </h3>
        <p class="text-t12 text-text-primary lg:text-body">
          Чиллеры AQUA THERMAL GM&nbsp;—<br />
          эксклюзивно на&nbsp;складе в&nbsp;«Даичи»
        </p>
      </article>

      <!-- CTA: Оставить заявку (Figma node 398:991, hover variant 398:992).
           Hover = ПОЛНАЯ инверсия: bg → светлый, текст → тёмный, круг → brand,
           стрелка → светлая.

           Bg меняется через opacity-overlay (а не `transition-colors`):
           CSS цветовая интерполяция brand → near-white проходит через тусклый
           промежуточный grey — на большой площади выглядит грязно. Opacity-
           crossfade 300ms даёт плавный «фотомонтажный» переход.
           Текст и иконка — мелкие по площади, для них transition-colors
           300ms ease-out читается чисто. -->
      <a
        href="#contact"
        data-reveal
        data-reveal-delay="240"
        class="group relative flex h-12 items-center justify-center overflow-hidden rounded-lg bg-brand px-5 lg:h-auto lg:flex-col lg:items-end lg:justify-between lg:rounded-3xl lg:p-6"
      >
        <!-- Hover-bg overlay поверх bg-brand: только на десктопе. -->
        <span
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 hidden bg-[#EFF2F5] opacity-0 transition-opacity duration-300 ease-out group-hover:opacity-100 lg:block"
        >
        </span>

        <p
          class="relative w-full text-center text-body font-medium text-white lg:text-left lg:text-h2 lg:transition-colors lg:duration-300 lg:ease-out lg:group-hover:text-text-inverse"
        >
          Оставить заявку
        </p>
        <span
          class="relative hidden h-12 w-12 items-center justify-center rounded-full bg-white text-brand transition-colors duration-300 ease-out group-hover:bg-brand group-hover:text-[#EFF2F5] lg:flex"
          aria-hidden="true"
        >
          <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M8.96973 2.96967C9.26262 2.67678 9.73738 2.67678 10.0303 2.96967L14.5303 7.46967C14.8232 7.76256 14.8232 8.23732 14.5303 8.53022L10.0303 13.0302C9.73738 13.3231 9.26262 13.3231 8.96973 13.0302C8.67683 12.7373 8.67683 12.2626 8.96973 11.9697L12.1895 8.74994L2 8.74994C1.58579 8.74994 1.25 8.41416 1.25 7.99994C1.25 7.58573 1.58579 7.24994 2 7.24994L12.1895 7.24994L8.96973 4.03022C8.67683 3.73732 8.67683 3.26256 8.96973 2.96967Z"
            />
          </svg>
        </span>
      </a>
    </div>
  </div>
  </div>
</section>

<!-- Модалка с видео — открывается из кнопки [data-video-trigger]. -->
<VideoModal />

<style is:global>
  /* Mobile: отключаем scroll-driven «выезд» Order'а из-под Contact —
     оставляем секцию в natural position. Inline `transform: translateY(60px)`
     перебиваем !important (специфичность инлайна 1000), плюс убрали
     -mt-[60px] из класса (теперь lg:-mt-[60px]). На десктопе CSS не
     срабатывает, JS управляет анимацией. */
  @media (max-width: 639px) {
    [data-order-section] {
      transform: none !important;
    }
  }
</style>

<script>
  /** Scroll-driven translate: Order «выезжает» из-под Contact (только десктоп).
   *  Старт: section.transform = translateY(60px) — установлен inline
   *  на самой секции (см. атрибут `style`), чтобы первый paint уже был
   *  в правильной стартовой позиции, без вспышки.
   *
   *  Прогресс считается от позиции верхнего края Order относительно
   *  viewport: 0 когда top на уровне нижнего края (только показалась),
   *  1 когда top достигает 40% высоты viewport (уверенно в кадре).
   *  Линейная интерполяция между ними даёт плавный 1-в-1 скролл-driven
   *  motion. При prefers-reduced-motion / mobile — фиксируем translateY(0). */
  const section = document.querySelector<HTMLElement>("[data-order-section]");
  if (section) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isMobile = window.innerWidth < 640;
    if (reduce || isMobile) {
      // Mobile: CSS уже занулил transform через !important; для consistency
      // также чистим inline-style (на случай ресайза с десктопа на мобилу).
      section.style.transform = "";
    } else {
      const MAX_TRANSLATE = 60;
      let rafId: number | null = null;

      const update = () => {
        rafId = null;
        const rect = section.getBoundingClientRect();
        const vh = window.innerHeight;
        const start = vh;
        const end = vh * 0.4;
        let progress = (start - rect.top) / (start - end);
        progress = Math.max(0, Math.min(1, progress));
        const translateY = MAX_TRANSLATE * (1 - progress);
        // При translateY=0 убираем transform полностью (а не translateY(0px)):
        // identity-transform всё равно создаёт GPU-compositor-layer, на границе
        // которого появляется тонкий subpixel-просвет — через него виден body-bg
        // (#0a0d12), который темнее bg-ink-base (#0f1115). Полное снятие
        // transform возвращает Order на основной слой, и шов исчезает.
        if (translateY === 0) {
          section.style.transform = "";
        } else {
          section.style.transform = `translateY(${translateY}px)`;
        }
      };

      const onScroll = () => {
        if (rafId !== null) return;
        rafId = requestAnimationFrame(update);
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });
      update();
    }
  }
</script>
