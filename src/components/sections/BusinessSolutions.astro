---
import { asset } from "../../lib/asset";
/**
 * Блок «Найдём решение для любого бизнеса» (figma 748:3160).
 * Десктоп: левая колонка — заголовок (text-h1, "Найдём решение " в брэнд-
 * градиенте), правая — 3 пронумерованных пункта с разделителями.
 * Внизу — отдельный sub-card "Программа подбора чиллеров Midea" с bg-фото,
 * двойным заголовком (gradient + plain) и CTA-кнопкой.
 */
import Button from "../Button.astro";

interface Solution {
  number: string;
  title: string;
  /** Параграф или массив строк — массив рендерится как стопка <p> */
  description: string | string[];
}

const solutions: Solution[] = [
  {
    number: "01",
    title: "Инженерным компаниям",
    description: [
      "Всё для реализации ваших проектов:",
      "складская программа;",
      "дооснащение низкотемпературным комплектом;",
      "эксклюзивные решения без аналогов в РФ.",
    ],
  },
  {
    number: "02",
    title: "Застройщикам",
    description: "Бренд чиллера не ограничивает выбор фанкойлов — покупатель квартиры свободен в выборе любого производителя и типа.",
  },
  {
    number: "03",
    title: "Проектировщикам",
    description: [
      "Профессиональное сопровождение на всех этапах:",
      "от разработки концепции до проверки гидравлических схем;",
      "поможем оптимизировать проект;",
      "переподберём оборудование для решения из наличия.",
    ],
  },
];
---

<!-- Full-bleed dark panel: bg-ink-surface растянут на всю ширину viewport
     (без container-x снаружи), rounded-3xl (24px) — углы прижаты к краям
     экрана по бокам, видны как изгиб сверху/снизу при переходе от body
     bg-ink-900 к panel bg-ink-surface. Контент внутри — в container-x для
     стандартного padding 40px. -->
<!-- relative z-30 — выше Projects (z-10), чтобы при скролле наезжать
     сверху на залипшую Projects-секцию (curtain-эффект). bg-ink-surface
     opaque закрывает Projects по мере перекрытия. -->
<section
  data-mobile-slide-up
  class="relative z-30 rounded-2xl bg-ink-surface lg:rounded-3xl"
>
  <div class="container-x flex flex-col gap-12 py-12 lg:gap-16 lg:py-20">
    <!-- Верхний ряд: заголовок (на мобиле сверху centered, на десктопе слева),
         нумерованные пункты (на мобиле — list ниже, на десктопе — справа). -->
    <div class="flex flex-col items-start gap-6 lg:flex-row lg:gap-16">
      <h2 data-reveal class="w-full text-center text-h2 font-medium text-text-primary lg:flex-1 lg:text-left lg:text-h1">
        <span class="gradient-text">Найдём решение</span><br />
        для&nbsp;любого бизнеса
      </h2>

      <ul class="flex w-full flex-1 flex-col">
        {
          solutions.map((s, idx) => {
            const lines = Array.isArray(s.description) ? s.description : null;
            const intro = lines ? lines[0] : null;
            const items = lines ? lines.slice(1) : [];
            return (
              <li
                data-reveal
                data-reveal-delay={idx * 80}
                class:list={[
                  "flex flex-col gap-4 lg:flex-row lg:items-baseline lg:gap-12",
                  idx === 0 ? "pb-6 lg:pb-12" : "",
                  idx > 0 && idx < solutions.length - 1 ? "border-t-[1.5px] border-strong py-6 lg:py-12" : "",
                  idx === solutions.length - 1 ? "border-t-[1.5px] border-strong pt-6 lg:pt-12" : "",
                ]}
              >
                <span class="shrink-0 text-h4 font-medium text-brand lg:text-h2">{s.number}</span>
                <div class="flex flex-1 flex-col gap-2 lg:gap-4">
                  <h3 class="text-h4 font-medium text-white lg:text-h2">{s.title}</h3>
                  {lines ? (
                    <div class="flex flex-col gap-2 text-t12 text-white lg:text-body">
                      {intro && <p>{intro}</p>}
                      {items.length > 0 && (
                        <ul class="dash-list flex flex-col gap-2">
                          {items.map((item) => (
                            <li>{item}</li>
                          ))}
                        </ul>
                      )}
                    </div>
                  ) : (
                    <p class="text-t12 text-white lg:text-body">{s.description}</p>
                  )}
                </div>
              </li>
            );
          })
        }
      </ul>
    </div>

    <!-- Custom Solutions: на мобиле image-сверху h-190 + текст + кнопка
         столбиком; на десктопе — bg-фото на всю h-32.5625rem с overlay. -->
    <article
      data-reveal
      class="flex flex-col gap-4 lg:relative lg:h-[32.5625rem] lg:items-start lg:justify-between lg:overflow-hidden lg:rounded-3xl lg:px-10 lg:py-12"
    >
      <div class="relative h-[11.875rem] w-full overflow-hidden rounded-2xl lg:absolute lg:inset-0 lg:-z-10 lg:h-auto lg:rounded-3xl">
        <img
          src={asset("/images/business-custom.jpg")}
          alt=""
          width="2720"
          height="1042"
          loading="lazy"
          decoding="async"
          class="pointer-events-none absolute inset-0 h-full w-full object-cover object-right lg:object-center"
        />
      </div>
      <div class="flex flex-col gap-2 text-center lg:gap-6 lg:text-left">
        <h3 class="text-h4 font-medium text-text-primary lg:w-[25rem] lg:text-h2">
          <span class="gradient-text">Программа подбора</span><br />
          чиллеров Midea
        </h3>
        <p class="text-t12 text-text-primary lg:w-[25rem] lg:text-body">
          Подберите оптимальную модель самостоятельно благодаря нашим инструментам&nbsp;— без&nbsp;запросов,
          ожидания и&nbsp;лишних согласований.
        </p>
      </div>
      <a
        href="#contact"
        class="inline-flex h-12 w-full items-center justify-center rounded-lg bg-brand px-5 text-body font-medium text-white lg:w-auto lg:hidden"
      >
        Оставить заявку
      </a>
      <Button href="#contact" class="hidden lg:inline-flex">Оставить заявку</Button>
    </article>
  </div>
</section>
