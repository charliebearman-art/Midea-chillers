---
/**
 * Карточка-кнопка для открытия видео-плеера Rutube. Сама модалка
 * рендерится отдельно через VideoCardModal.astro (один singleton
 * на странице, ловит все [data-video-card] клики).
 */
interface Props {
  /** Embed-URL Rutube-плеера (вида https://rutube.ru/play/embed/<ID>?…) */
  videoSrc?: string;
  label?: string;
}

const {
  videoSrc = "https://rutube.ru/play/embed/4bdb493e271ad3e31837f63c48fb7e26/?skinColor=32A3FD",
  label = "Видео о продукте",
} = Astro.props;
---

<button
  type="button"
  data-video-card
  data-video-src={videoSrc}
  class="relative flex h-[11.875rem] w-[11.875rem] shrink-0 flex-col justify-between overflow-hidden rounded-2xl border border-strong bg-glass-surface p-4 backdrop-blur-glass transition-all duration-500 ease-out hover:bg-white/[0.16] hover:scale-[1.03] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
  aria-label={`Открыть ${label.toLowerCase()}`}
>
  <span
    class="flex h-12 w-12 items-center justify-center rounded-full bg-white text-ink-900 transition-transform duration-300 group-hover:scale-110"
  >
    <!-- иконка play. viewBox + класс h-4 — флюид-размер вместе с rem
         (а не фикс 14×16px). aspect-ratio 14:16 удерживает viewBox. -->
    <svg viewBox="0 0 14 16" fill="none" aria-hidden="true" class="h-4 w-auto">
      <path d="M13 7.13397C13.6667 7.51887 13.6667 8.48113 13 8.86603L2 15.2206C1.33333 15.6055 0.5 15.1244 0.5 14.3546L0.5 1.64545C0.5 0.875645 1.33333 0.394521 2 0.779421L13 7.13397Z" fill="currentColor"/>
    </svg>
  </span>

  <span class="text-left text-body font-medium text-text-primary">
    {label}
  </span>
</button>
