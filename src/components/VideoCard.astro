---
/**
 * Карточка-кнопка для открытия видео-плеера Rutube в модалке.
 * iframe-src ленивая: пустой по умолчанию, заполняется при клике (без
 * фоновых сетевых запросов до открытия). При закрытии — снимаем src,
 * чтобы плеер прекратил воспроизведение и отключился от сети.
 */
interface Props {
  /** Embed-URL Rutube-плеера (вида https://rutube.ru/play/embed/<ID>?…) */
  videoSrc?: string;
  label?: string;
}

const {
  videoSrc = "https://rutube.ru/play/embed/4bdb493e271ad3e31837f63c48fb7e26/?skinColor=32A3FD",
  label = "Видео о продукте",
} = Astro.props;
---

<button
  type="button"
  data-video-card
  data-video-src={videoSrc}
  class="relative flex h-[11.875rem] w-[11.875rem] shrink-0 flex-col justify-between overflow-hidden rounded-2xl border border-strong bg-glass-surface p-4 backdrop-blur-glass transition-all duration-500 ease-out hover:bg-white/[0.16] hover:scale-[1.03] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand"
  aria-label={`Открыть ${label.toLowerCase()}`}
>
  <span
    class="flex h-12 w-12 items-center justify-center rounded-full bg-white text-ink-900 transition-transform duration-300 group-hover:scale-110"
  >
    <!-- иконка play -->
    <svg width="14" height="16" viewBox="0 0 14 16" fill="none" aria-hidden="true">
      <path d="M13 7.13397C13.6667 7.51887 13.6667 8.48113 13 8.86603L2 15.2206C1.33333 15.6055 0.5 15.1244 0.5 14.3546L0.5 1.64545C0.5 0.875645 1.33333 0.394521 2 0.779421L13 7.13397Z" fill="currentColor"/>
    </svg>
  </span>

  <span class="text-left text-body font-medium text-text-primary">
    {label}
  </span>
</button>

<!-- Лайтбокс для Rutube iframe; рендерится один раз на странице -->
<dialog
  data-video-dialog
  class="m-auto rounded-2xl border border-strong bg-ink-900/95 p-0 backdrop:bg-black/80 backdrop:backdrop-blur-sm w-[min(90vw,1100px)]"
>
  <div class="relative aspect-video w-full">
    <button
      type="button"
      data-video-close
      aria-label="Закрыть"
      class="absolute right-3 top-3 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-black/60 text-white transition hover:bg-black/80"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 3L13 13M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <iframe
      data-video-player
      title="Видео о продукте"
      allow="clipboard-write; autoplay"
      allowfullscreen
      class="h-full w-full rounded-2xl border-0 bg-black"
    >
    </iframe>
  </div>
</dialog>

<script>
  /** Ленивая загрузка Rutube-iframe: src ставим только при открытии диалога,
   *  снимаем при закрытии. Это не запускает фоновые запросы до клика и
   *  останавливает воспроизведение/трекинг при закрытии. */
  const cards = document.querySelectorAll<HTMLButtonElement>("[data-video-card]");
  const dialog = document.querySelector<HTMLDialogElement>("[data-video-dialog]");
  const player = dialog?.querySelector<HTMLIFrameElement>("[data-video-player]");
  const closeBtn = dialog?.querySelector<HTMLButtonElement>("[data-video-close]");

  if (dialog && player && closeBtn) {
    cards.forEach((card) => {
      card.addEventListener("click", () => {
        const src = card.dataset.videoSrc;
        if (src) player.src = src;
        dialog.showModal();
      });
    });

    const close = () => {
      // Снимаем src — это останавливает Rutube-плеер и закрывает соединение.
      player.removeAttribute("src");
      dialog.close();
    };

    closeBtn.addEventListener("click", close);
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) close();
    });
    dialog.addEventListener("close", () => {
      player.removeAttribute("src");
    });
  }
</script>
