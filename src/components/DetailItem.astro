---
/**
 * Карточка-деталь: номер слева, текст по центру, картинка справа.
 * Используется в секции "Готовое решение от производителя чиллеров №1".
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  number: string;
  /** Первая часть заголовка с акцентом-градиентом (e.g. "На 45% дешевле,") */
  highlight: string;
  /** Остаток заголовка обычным цветом (e.g. "чем чиллер + отдельный гидромодуль") */
  title: string;
  /** Текст описания. Можно строкой или массивом (тогда выводим списком) */
  description: string | string[];
  /** ImageMetadata из import — Astro строит WebP, проставляет width/height. */
  image: ImageMetadata;
  imageAlt?: string;
}

const { number, highlight, title, description, image, imageAlt = "" } = Astro.props;
const isList = Array.isArray(description);
---

<!-- На мобиле: картинка сверху (aspect 572/350), текст снизу — flex-col-reverse
     инвертирует порядок DOM (text-first → image-first визуально). На десктопе
     lg:flex-row → text слева + картинка справа, sticky-стек, h-22.375rem.
     Номер виден только на десктопе. -->
<article
  data-reveal
  data-reveal-mobile-scale
  data-reveal-image
  class="relative flex h-[32rem] flex-col-reverse overflow-hidden rounded-3xl border-2 border-strong bg-glass-deep p-2 backdrop-blur-[12px] lg:h-[22.375rem] lg:flex-row lg:items-stretch lg:gap-12 lg:backdrop-blur-[1.5rem]"
>
  <!-- Текст (на мобиле gap=0 у article, padding на этом блоке px-2 py-4;
       на десктопе тут флекс-строка с номером + контентом, p-6). -->
  <div class="flex flex-1 px-2 py-4 lg:gap-12 lg:p-6">
    <span class="hidden shrink-0 w-20 text-h3 font-medium text-text-primary lg:block">
      {number}
    </span>
    <div class="flex flex-1 flex-col justify-between gap-2 lg:gap-6">
      <h3 class="text-h4 font-medium text-text-primary lg:text-h3">
        <span class="gradient-text">{highlight}</span><br />
        {title}
      </h3>

      {
        isList ? (
          <ul class="dash-list flex flex-col gap-2 text-t12 text-text-primary lg:text-body">
            {(description as string[]).map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        ) : (
          <p class="text-t12 text-text-primary lg:text-body">{description}</p>
        )
      }
    </div>
  </div>

  <!-- Картинка: на мобиле aspect-[572/350] на всю ширину, на десктопе
       фиксированная w-34.9375rem справа (flex-row + items-stretch
       растягивают её по высоте article). -->
  <div class="relative aspect-[572/350] w-full shrink-0 overflow-hidden rounded-2xl lg:aspect-auto lg:h-auto lg:w-[34.9375rem]">
    <Image
      src={image}
      alt={imageAlt}
      widths={[559, 1118]}
      sizes="(min-width: 640px) 559px, 100vw"
      loading="lazy"
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover"
    />
  </div>
</article>
